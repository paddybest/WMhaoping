.container {
  min-height: 100vh;
  background: #F7F8FA;
  padding-bottom: 200rpx;
}

.error-header {
  background: #FEF2F2;
  padding: 50rpx 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.error-icon {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: #EF4444;
  color: #FFFFFF;
  font-size: 60rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
}

.error-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #DC2626;
  margin-bottom: 12rpx;
}

.error-reason {
  font-size: 28rpx;
  color: #991B1B;
  text-align: center;
}

.guide-section {
  background: #FFFFFF;
  margin: 20rpx;
  border-radius: 20rpx;
  padding: 30rpx;
}

.guide-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1F2937;
  margin-bottom: 30rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid #F3F4F6;
}

.step-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 30rpx;
}

.step-item:last-child {
  margin-bottom: 0;
}

.step-number {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #3B82F6;
  color: #FFFFFF;
  font-size: 26rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.step-content {
  flex: 1;
}

.step-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #1F2937;
  margin-bottom: 8rpx;
}

.step-desc {
  font-size: 26rpx;
  color: #6B7280;
}

.tips-section {
  background: #FEF3C7;
  margin: 20rpx;
  border-radius: 20rpx;
  padding: 30rpx;
}

.tips-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #92400E;
  margin-bottom: 16rpx;
}

.tip-item {
  font-size: 26rpx;
  color: #B45309;
  line-height: 1.8;
  padding-left: 20rpx;
  position: relative;
}

.tip-item::before {
  content: '•';
  position: absolute;
  left: 0;
}

.footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #FFFFFF;
  padding: 30rpx;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.primary-btn {
  width: 100%;
  height: 90rpx;
  background: linear-gradient(135deg, #3B82F6, #2563EB);
  border-radius: 45rpx;
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  margin-bottom: 20rpx;
}

.secondary-btn {
  width: 100%;
  height: 90rpx;
  background: #FFFFFF;
  border: 2rpx solid #3B82F6;
  border-radius: 45rpx;
  color: #3B82F6;
  font-size: 32rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
}
