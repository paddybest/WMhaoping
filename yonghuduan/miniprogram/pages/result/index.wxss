.container {
  display: flex;
  flex-direction: column;
  align-items: stretch;
  min-height: 100vh;
  background: #F0F2F5;
}

.header {
  background: #FFFFFF;
  padding: 30rpx;
  border-bottom: 1rpx solid #EEE;
}

.step-indicator {
  display: flex;
  align-items: center;
  justify-content: center;
}

.step {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.step-circle {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #E5E7EB;
  color: #9CA3AF;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 500;
  margin-bottom: 12rpx;
}

.step.active .step-circle {
  background: #3B82F6;
  color: #FFFFFF;
}

.step.completed .step-circle {
  background: #10B981;
  color: #FFFFFF;
}

.step-text {
  font-size: 24rpx;
  color: #9CA3AF;
}

.step.active .step-text {
  color: #3B82F6;
  font-weight: 500;
}

.step.completed .step-text {
  color: #10B981;
}

.step-line {
  width: 60rpx;
  height: 4rpx;
  background: #E5E7EB;
  margin: 0 16rpx;
  margin-bottom: 36rpx;
}

.step-line.completed {
  background: #10B981;
}

.section {
  background: #FEFEFE;
  margin: 0 20rpx 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.product-badge {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx;
  background: linear-gradient(135deg, #667EEA, #764BA2);
}

.badge-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.badge-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #FFFFFF;
}

.tags-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx 16rpx;
}

.tags-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.tags-hint {
  font-size: 22rpx;
  color: #999;
}

.tags-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 0 20rpx 20rpx;
  gap: 16rpx;
}

.tag-item {
  padding: 14rpx 28rpx;
  background: #F5F7FA;
  border-radius: 24rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s ease;
}

.tag-item.selected {
  background: #EEF2FF;
  border-color: #6366F1;
}

.tag-item.selected .tag-text {
  color: #6366F1;
  font-weight: 500;
}

.tag-text {
  font-size: 26rpx;
  color: #666;
}

.empty-tags {
  padding: 40rpx;
  text-align: center;
  color: #999;
  font-size: 26rpx;
}

.generate-section {
  padding: 0 24rpx 20rpx;
}

.generate-btn {
  width: 100%;
  height: 84rpx;
  border-radius: 42rpx;
  font-size: 30rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.generate-btn.active {
  background: linear-gradient(135deg, #6366F1, #4F46E5);
  color: #FFFFFF;
  box-shadow: 0 4rpx 16rpx rgba(99, 102, 241, 0.35);
}

.generate-btn.disabled {
  background: #E5E7EB;
  color: #999;
}

.product-info {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
}

.product-label {
  font-size: 24rpx;
  color: #999;
  margin-right: 12rpx;
}

.product-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.section-title {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.section-title.center {
  justify-content: center;
}

.text-content {
  font-size: 28rpx;
  line-height: 1.8;
  color: #444;
  padding: 24rpx;
}

.review-image {
  width: 100%;
  height: 300rpx;
  display: block;
}

.jump-buttons {
  display: flex;
  padding: 24rpx;
}

.jump-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 32rpx 24rpx;
  border-radius: 12rpx;
  margin: 0 12rpx;
}

.jump-btn:active {
  opacity: 0.85;
}

.jump-btn.meituan {
  background: #FFF8E1;
  border: 2rpx solid #FFD100;
}

.jump-btn.eleme {
  background: #E6F4FF;
  border: 2rpx solid #00A0E9;
}

.jump-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 12rpx;
}

.jump-btn.meituan .jump-icon {
  background: linear-gradient(135deg, #FFD100, #FF9500);
  color: #FFFFFF;
}

.jump-btn.eleme .jump-icon {
  background: linear-gradient(135deg, #00A0E9, #0078D7);
  color: #FFFFFF;
}

.jump-text {
  font-size: 26rpx;
  font-weight: 500;
}

.jump-btn.meituan .jump-text {
  color: #FF9500;
}

.jump-btn.eleme .jump-text {
  color: #0078D7;
}

.action-buttons {
  display: flex;
  justify-content: center;
  padding: 24rpx;
  gap: 24rpx;
}

.action-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 96rpx;
  flex: 1;
  max-width: 320rpx;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: 500;
}

.save-btn {
  background: linear-gradient(135deg, #6366F1, #4F46E5);
  color: #FFFFFF;
}

.regenerate-btn {
  background: #F5F7FA;
  border: 2rpx solid #E5E7EB;
}

.regenerate-btn text {
  color: #666;
}

.regenerate-section {
  display: flex;
  justify-content: center;
  padding: 16rpx 24rpx 24rpx;
}
