/* Modern Customer Service Page Color Scheme */
.customer-service-container {
  min-height: 100vh;
  background: #FAFBFC;
  padding: 40rpx;
}

/* 头部样式 */
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 60rpx;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #1A202C;
}

.back-btn {
  background: #E2E8F0;
  color: #4A5568;
  padding: 16rpx 32rpx;
  border-radius: 30rpx;
  font-size: 28rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s ease;
}

.back-btn:active {
  transform: scale(0.95);
  background: #CBD5E0;
  color: #2D3748;
}

/* 内容区域 */
.content {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 40rpx;
  box-shadow: 0 4rpx 20rpx rgba(26, 32, 44, 0.08);
  border: 1rpx solid rgba(226, 232, 240, 0.5);
}

.section-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #1A202C;
  margin-bottom: 30rpx;
}

/* 奖励码区域 */
.reward-code-section {
  margin-bottom: 60rpx;
}

.code-display {
  background: linear-gradient(135deg, #F0FDF4 0%, #ECFDF5 100%);
  padding: 30rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border: 2rpx solid #D1FAE5;
  box-shadow: inset 0 2rpx 4rpx rgba(34, 197, 94, 0.1);
}

.code-display text {
  font-size: 40rpx;
  font-weight: bold;
  color: #059669;
  letter-spacing: 8rpx;
}

.copy-icon {
  color: #6B7280;
  transition: all 0.2s ease;
}

.copy-icon:active {
  transform: scale(0.9);
  color: #059669;
}

/* 二维码区域 */
.qr-section {
  margin-bottom: 60rpx;
  text-align: center;
}

.qr-container {
  width: 400rpx;
  height: 400rpx;
  margin: 0 auto 40rpx;
  background: #FFFFFF;
  border: 3rpx solid #E2E8F0;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
  transition: all 0.3s ease;
}

.qr-container:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.qr-image {
  width: 100%;
  height: 100%;
  border-radius: 17rpx;
}

.qr-mask {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(248, 250, 252, 0.95);
  backdrop-filter: blur(10rpx);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #6B7280;
  font-size: 28rpx;
  border-radius: 20rpx;
}

.save-btn {
  background: linear-gradient(135deg, #10B981 0%, #059669 100%);
  color: white;
  padding: 24rpx 60rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  border: none;
  margin-bottom: 40rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(16, 185, 129, 0.3);
  transition: all 0.3s ease;
}

.save-btn:active {
  transform: scale(0.95);
  opacity: 0.9;
}

/* 说明文字 */
.instruction {
  text-align: center;
}

.instruction-text {
  font-size: 28rpx;
  color: #4A5568;
  line-height: 1.6;
}

/* 加载状态 */
.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 400rpx;
}

.loading-text {
  font-size: 32rpx;
  color: #6B7280;
  font-weight: 500;
}

/* 错误状态 */
.error {
  text-align: center;
  padding: 60rpx;
}

.error-text {
  display: block;
  font-size: 32rpx;
  color: #EF4444;
  margin-bottom: 40rpx;
  font-weight: 500;
}

.retry-btn {
  background: linear-gradient(135deg, #EF4444 0%, #DC2626 100%);
  color: white;
  padding: 24rpx 60rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  border: none;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(239, 68, 68, 0.3);
  transition: all 0.3s ease;
}

.retry-btn:active {
  transform: scale(0.95);
  opacity: 0.9;
}

/* 响应式调整 */
@media (max-width: 750rpx) {
  .customer-service-container {
    padding: 20rpx;
  }

  .qr-container {
    width: 300rpx;
    height: 300rpx;
  }

  .code-display {
    font-size: 32rpx;
  }
}