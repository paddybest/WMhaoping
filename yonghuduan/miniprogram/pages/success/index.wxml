<view class="container">
  <view class="success-section">
    <view class="success-icon">
      <text class="icon">✓</text>
    </view>
    <text class="success-title">审核通过</text>
    <text class="success-subtitle">奖励已发放到您的账户</text>
    
    <view class="amount-section">
      <text class="amount-label">到账金额</text>
      <view class="amount-value">
        <text class="currency">¥</text>
        <text class="number">{{amount}}</text>
      </view>
    </view>
  </view>

  <view class="info-section">
    <view class="info-item">
      <text class="info-label">奖励类型</text>
      <text class="info-value">评价奖励</text>
    </view>
    <view class="info-item">
      <text class="info-label">到账时间</text>
      <text class="info-value">{{time}}</text>
    </view>
  </view>

  <view class="footer">
    <button class="primary-btn" bindtap="onGoHome">返回首页</button>
    <button class="secondary-btn" bindtap="onContinue">继续评价</button>
  </view>
</view>
