.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #F0FDF4 0%, #F7F8FA 30%);
  padding-bottom: 200rpx;
}

.success-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 30rpx 60rpx;
}

.success-icon {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #10B981, #059669);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 30rpx rgba(16, 185, 129, 0.3);
}

.success-icon .icon {
  font-size: 70rpx;
  color: #FFFFFF;
  font-weight: bold;
}

.success-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #059669;
  margin-bottom: 12rpx;
}

.success-subtitle {
  font-size: 28rpx;
  color: #6B7280;
}

.amount-section {
  margin-top: 50rpx;
  text-align: center;
}

.amount-label {
  font-size: 26rpx;
  color: #9CA3AF;
  margin-bottom: 16rpx;
  display: block;
}

.amount-value {
  display: flex;
  align-items: baseline;
  justify-content: center;
}

.currency {
  font-size: 40rpx;
  color: #059669;
  font-weight: 500;
}

.number {
  font-size: 80rpx;
  color: #059669;
  font-weight: 700;
}

.info-section {
  background: #FFFFFF;
  margin: 30rpx;
  border-radius: 20rpx;
  padding: 30rpx;
}

.info-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 2rpx solid #F3F4F6;
}

.info-item:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 28rpx;
  color: #6B7280;
}

.info-value {
  font-size: 28rpx;
  color: #1F2937;
  font-weight: 500;
}

.footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #FFFFFF;
  padding: 30rpx;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.primary-btn {
  width: 100%;
  height: 90rpx;
  background: linear-gradient(135deg, #10B981, #059669);
  border-radius: 45rpx;
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  margin-bottom: 20rpx;
}

.secondary-btn {
  width: 100%;
  height: 90rpx;
  background: #FFFFFF;
  border: 2rpx solid #10B981;
  border-radius: 45rpx;
  color: #10B981;
  font-size: 32rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
}
