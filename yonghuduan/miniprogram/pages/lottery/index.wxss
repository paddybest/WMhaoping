/* Modern Lottery Page Color Scheme */
.lottery-container {
  min-height: 100vh;
  background: linear-gradient(135deg, #2D3748 0%, #4A5568 50%, #2B6CB0 100%);
  padding: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  overflow: hidden;
}

/* Modern Background Effects */
.lottery-container::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: radial-gradient(circle at 30% 20%, rgba(102, 126, 234, 0.2) 0%, transparent 50%),
              radial-gradient(circle at 70% 80%, rgba(236, 72, 153, 0.1) 0%, transparent 50%);
  pointer-events: none;
}

/* 标题区样式 */
.header-section {
  margin-bottom: 60rpx;
  text-align: center;
  position: relative;
  z-index: 1;
}

.header-section .title {
  font-size: 48rpx;
  color: #FFFFFF;
  font-weight: bold;
  text-align: center;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.3);
}

.header-section .subtitle {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 16rpx;
  text-align: center;
}

.lottery-count {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-top: 12rpx;
  text-align: center;
  padding: 8rpx 16rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 20rpx;
  display: inline-block;
}

/* 错误提示样式 */
.error-section {
  background: rgba(239, 68, 68, 0.1);
  border: 2rpx solid #EF4444;
  border-radius: 20rpx;
  padding: 60rpx;
  text-align: center;
  width: 90%;
  backdrop-filter: blur(10rpx);
  box-shadow: 0 8rpx 24rpx rgba(239, 68, 68, 0.2);
}

.error-message {
  color: #EF4444;
  font-size: 32rpx;
  margin-bottom: 40rpx;
  display: block;
  font-weight: 500;
}

.retry-btn {
  background: #EF4444;
  color: white;
  font-size: 28rpx;
  padding: 20rpx 60rpx;
  border-radius: 40rpx;
  border: none;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(239, 68, 68, 0.3);
  transition: all 0.2s ease;
}

.retry-btn:active {
  transform: scale(0.95);
}

/* 转盘区域样式 */
.wheel-section {
  position: relative;
  margin-bottom: 80rpx;
}

.spin-btn {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #F687B3 0%, #D53F8C 100%);
  color: white;
  font-size: 32rpx;
  border: none;
  box-shadow: 0 16rpx 40rpx rgba(245, 135, 179, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
  font-weight: 700;
  position: relative;
  z-index: 1;
}

.spin-btn::before {
  content: '';
  position: absolute;
  top: -4rpx;
  left: -4rpx;
  right: -4rpx;
  bottom: -4rpx;
  background: linear-gradient(135deg, #F687B3 0%, #D53F8C 100%);
  border-radius: 50%;
  opacity: 0.4;
  z-index: -1;
}

.spin-btn:active {
  transform: scale(0.9);
}

.spin-btn.disabled {
  background: #4A5568;
  box-shadow: none;
  opacity: 0.8;
}

/* 结果展示样式 */
.result-section {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  animation: fadeInUp 0.6s ease-out;
  position: relative;
  z-index: 1;
}

.prize-card {
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(10rpx);
  border-radius: 20rpx;
  padding: 40rpx;
  width: 90%;
  max-width: 600rpx;
  animation: prizePopUp 0.6s cubic-bezier(0.68, -0.55, 0.265, 1.55);
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.2);
  border: 1rpx solid rgba(255, 255, 255, 0.2);
}

.prize-title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #1A202C;
  text-align: center;
  margin-bottom: 30rpx;
}

.code-display {
  background: linear-gradient(135deg, #EBF4FF 0%, #E0E7FF 100%);
  padding: 30rpx;
  border-radius: 10rpx;
  text-align: center;
  font-size: 48rpx;
  font-weight: bold;
  color: #5A67D8;
  letter-spacing: 8rpx;
  margin: 30rpx 0;
  position: relative;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: inset 0 2rpx 4rpx rgba(90, 103, 216, 0.1);
  border: 1rpx solid rgba(90, 103, 216, 0.2);
}

.code-display text {
  flex: 1;
}

.action-buttons {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-top: 40rpx;
  width: 100%;
}

.action-btn {
  padding: 30rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  border: none;
  transition: all 0.3s ease;
  font-weight: 600;
}

.action-btn.primary {
  background: linear-gradient(135deg, #667EEA 0%, #5A67D8 100%);
  color: white;
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.3);
}

.action-btn.secondary {
  background: rgba(255, 255, 255, 0.9);
  color: #2D3748;
  border: 2rpx solid rgba(255, 255, 255, 0.3);
  backdrop-filter: blur(10rpx);
}

.action-btn:active {
  transform: scale(0.98);
}

/* 动画效果 */
@keyframes prizePopUp {
  0% {
    transform: scale(0.5);
    opacity: 0;
  }
  60% {
    transform: scale(1.1);
  }
  100% {
    transform: scale(1);
    opacity: 1;
  }
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(30rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* 彩带动画 */
.confetti-layer {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
  z-index: 999;
  overflow: hidden;
}

.confetti-piece {
  position: absolute;
  top: -100rpx;
  border-radius: 50%;
  opacity: 0.8;
  animation: confettiFall 3s ease-in forwards;
}

@keyframes confettiFall {
  0% {
    transform: translateY(-100vh) rotate(0deg) translateX(0);
    opacity: 1;
  }
  100% {
    transform: translateY(100vh) rotate(360deg) translateX(200rpx);
    opacity: 0;
  }
}

/* 结果展示样式 */
.result-section {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 24rpx;
  padding: 60rpx;
  width: 90%;
  text-align: center;
  backdrop-filter: blur(10rpx);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.2);
}

.result-section .prize-card {
  padding: 0;
}

.result-section .prize-title {
  font-size: 36rpx;
  color: #1A202C;
  font-weight: bold;
  margin-bottom: 40rpx;
}

/* 中奖奖品大图 */
.prize-image-large {
  width: 200rpx;
  height: 200rpx;
  margin: 0 auto 30rpx;
  display: block;
  border-radius: 20rpx;
}

/* 奖品名称 */
.prize-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #1A202C;
  text-align: center;
  margin-bottom: 16rpx;
  display: block;
}

/* 奖品描述 */
.prize-description {
  font-size: 28rpx;
  color: #4A5568;
  text-align: center;
  margin-bottom: 30rpx;
  line-height: 1.5;
}

/* 兑换码显示 */
.code-display {
  background: #F7FAFC;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.code-display .code-label {
  font-size: 28rpx;
  color: #4A5568;
  margin-right: 12rpx;
}

.code-display .code-value {
  font-size: 32rpx;
  font-weight: 600;
  color: #2D3748;
  letter-spacing: 4rpx;
  flex: 1;
}

.code-display .copy-btn {
  background: #667EEA;
  color: white;
  border: none;
  border-radius: 8rpx;
  padding: 8rpx 16rpx;
  font-size: 24rpx;
  margin-left: 16rpx;
}

/* 操作按钮 */
.action-buttons {
  display: flex;
  gap: 30rpx;
  justify-content: center;
}

.action-btn {
  width: 200rpx;
  height: 80rpx;
  border-radius: 40rpx;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
  transition: all 0.3s ease;
}

.action-btn.primary {
  background: linear-gradient(135deg, #667EEA 0%, #764BA2 100%);
  color: white;
}

.action-btn.integrated-btn {
  background: linear-gradient(135deg, #48BB78 0%, #38A169 100%);
  color: white;
  font-size: 30rpx;
  padding: 24rpx 32rpx;
  border-radius: 12rpx;
  box-shadow: 0 6rpx 16rpx rgba(72, 187, 120, 0.3);
}

.action-btn.secondary {
  background: transparent;
  color: #667EEA;
  border: 2rpx solid #667EEA;
}

/* 响应式调整 */
@media (max-width: 750rpx) {
  .lottery-container {
    padding: 20rpx;
  }

  .prize-card {
    width: 95%;
  }

  .code-display {
    font-size: 40rpx;
  }
}