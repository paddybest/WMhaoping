/* ========================================
   AI 评价助手 - 现代简约设计
   ======================================== */

/* 基础容器 */
.container {
  min-height: 100vh;
  background: #F8F9FB; /* 极浅灰白色背景 */
  padding: 20rpx;
  padding-bottom: 40rpx;
}

/* 卡片全宽适配 */
.card {
  background: #FFFFFF;
  border-radius: 20px;
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
  padding: 32rpx;
  margin-bottom: 24rpx;
  width: 100%;
  box-sizing: border-box;
}

/* Header 头部 */
.header {
  text-align: center;
  margin-bottom: 40rpx;
  padding-top: 20rpx;
}

.title {
  display: block;
  font-size: 52rpx;
  font-weight: 700; /* 粗体标题 */
  color: #1A202C;
  letter-spacing: 2rpx;
  margin-bottom: 12rpx;
}

.subtitle {
  display: block;
  font-size: 28rpx;
  color: #A0AEC0; /* 浅灰色副标题 */
  font-weight: 400;
}

/* 卡片头部 */
.card-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.card-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #2D3748;
}

/* ========================================
   品类选择器
   ======================================== */
.category-card {
  position: relative;
}

.picker-wrapper {
  position: relative;
}

.picker-display {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  padding: 0 32rpx;
  background: #F7FAFC;
  border: 2rpx solid #E2E8F0;
  border-radius: 16rpx;
  box-sizing: border-box;
  overflow: hidden;
}

.picker-display:active {
  background: #EDF2F7;
  transform: scale(0.98);
}

.picker-text {
  font-size: 30rpx;
  color: #2D3748;
  font-weight: 500;
}

.picker-text.placeholder {
  color: #A0AEC0;
}

.arrow {
  font-size: 24rpx;
  color: #A0AEC0;
}

.arrow.rotate {
  transform: rotate(180deg);
}

/* 下拉菜单 */
.dropdown-menu {
  position: absolute;
  top: 100%;
  left: 0;
  right: 0;
  background: #FFFFFF;
  border-radius: 16rpx;
  box-shadow: 0 8px 30px rgba(0, 0, 0, 0.12);
  max-height: 0;
  overflow: hidden;
  transition: all 0.3s ease;
  opacity: 0;
  z-index: 100;
  margin-top: 8rpx;
}

.dropdown-menu.show {
  max-height: 400rpx;
  opacity: 1;
  overflow-y: auto;
}

.dropdown-item {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 20rpx;
  border-bottom: 1rpx solid #EDF2F7;
  transition: background 0.2s ease;
  box-sizing: border-box;
}

.dropdown-item:last-child {
  border-bottom: none;
}

.dropdown-item:active {
  background: #F7FAFC;
}

.dropdown-item.selected {
  background: linear-gradient(135deg, #4FACFE, #00F2FE);
}

.dropdown-item.selected .dropdown-text {
  color: #FFFFFF;
  font-weight: 600;
}

.dropdown-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
}

.dropdown-text {
  font-size: 30rpx;
  color: #4A5568;
  text-align: center;
  line-height: 1;
}

/* ========================================
   评价标签
   ======================================== */
.tags-card {
  margin-top: 24rpx;
}

.tags-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

/* 标签未选中状态 */
.tag-item {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx 32rpx;
  background: #F1F5F9;
  border: 2rpx solid #E2E8F0;
  border-radius: 40rpx;
  transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
}

.tag-item:active {
  transform: scale(0.95);
}

/* 标签选中状态 */
.tag-item.selected {
  background: linear-gradient(135deg, #EBF4FF, #DBEAFE);
  border-color: #3B82F6;
  box-shadow: 0 4px 12px rgba(59, 130, 246, 0.25);
}

.tag-item.selected .tag-text {
  color: #1D4ED8;
  font-weight: 600;
}

.tag-text {
  font-size: 28rpx;
  color: #4B5563;
  font-weight: 500;
  transition: all 0.25s ease;
}

.tag-check {
  margin-left: 8rpx;
  font-size: 20rpx;
  color: #3B82F6;
  font-weight: bold;
}

/* ========================================
   评分组件
   ======================================== */
.rating-card {
  margin-top: 24rpx;
}

.rating-stars {
  display: flex;
  justify-content: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.star {
  font-size: 64rpx;
  color: #E2E8F0; /* 浅灰色未选中 */
  transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  cursor: pointer;
  line-height: 1;
}

.star:active {
  transform: scale(1.3) rotate(15deg);
}

.star.active {
  color: #FFC107; /* 明亮琥珀色 */
  animation: starPop 0.4s ease-out;
}

@keyframes starPop {
  0% { transform: scale(1); }
  50% { transform: scale(1.3); }
  100% { transform: scale(1); }
}

.rating-text {
  text-align: center;
  font-size: 30rpx;
  color: #A0AEC0;
  font-weight: 500;
  min-height: 40rpx;
  transition: all 0.3s ease;
}

.rating-text.active {
  color: #F59E0B;
  font-weight: 600;
}

/* ========================================
   主按钮（嵌入页面流程）
   ======================================== */
card.generate-card {
  margin-top: 24rpx;
  padding: 16rpx;
}

.generate-btn {
  width: 100%;
  height: 96rpx;
  border-radius: 48rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  overflow: hidden;
}

/* 禁用状态 */
.generate-btn.disabled {
  background: #E2E8F0;
  box-shadow: none;
}

.generate-btn.disabled .btn-text {
  color: #A0AEC0;
}

/* 可点击状态 - 渐变蓝紫色 */
.generate-btn.active {
  background: linear-gradient(135deg, #667EEA 0%, #764BA2 100%);
  box-shadow: 0 8px 24px rgba(102, 126, 234, 0.4);
}

.generate-btn.active:active {
  transform: scale(0.98);
  box-shadow: 0 4px 12px rgba(102, 126, 234, 0.3);
}

/* 按钮文字 */
.btn-text {
  font-size: 34rpx;
  font-weight: 600;
  color: #FFFFFF;
  letter-spacing: 1rpx;
}

.btn-loading {
  font-size: 32rpx;
  color: #FFFFFF;
}

/* 按钮点击波纹效果 */
.generate-btn::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 0;
  height: 0;
  background: rgba(255, 255, 255, 0.3);
  border-radius: 50%;
  transform: translate(-50%, -50%);
  transition: width 0.6s, height 0.6s;
}

.generate-btn:active::after {
  width: 300rpx;
  height: 300rpx;
}

/* ========================================
   生成结果卡片
   ======================================== */
.result-card {
  margin-top: 24rpx;
}

.result-content {
  background: linear-gradient(135deg, #F0F9FF, #E6FFFA);
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.result-text {
  font-size: 30rpx;
  color: #2D3748;
  line-height: 1.8;
  font-weight: 500;
}

.result-actions {
  display: flex;
  justify-content: flex-end;
}

.copy-btn {
  background: linear-gradient(135deg, #667EEA 0%, #764BA2 100%);
  color: #FFFFFF;
  border: none;
  border-radius: 32rpx;
  font-size: 28rpx;
  padding: 16rpx 40rpx;
}

/* ========================================
   商品选择模式（从二维码进入）
   ======================================== */
.selected-category {
  background: #F0F9FF;
  padding: 20rpx 24rpx;
  border-radius: 12rpx;
  margin-bottom: 24rpx;
  font-size: 28rpx;
  color: #2D3748;
}

.selected-product {
  background: #F0F9FF;
  padding: 24rpx;
  border-radius: 12rpx;
  margin-bottom: 24rpx;
  text-align: center;
}

.selected-product-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #1D4ED8;
}

.product-list {
  max-height: 500rpx;
  overflow-y: auto;
}

.product-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid #E2E8F0;
  transition: background 0.2s ease;
}

.product-item:last-child {
  border-bottom: none;
}

.product-item:active {
  background: #F7FAFC;
}

.product-radio {
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid #CBD5E0;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  font-size: 24rpx;
  color: #3B82F6;
  font-weight: bold;
}

.product-info {
  flex: 1;
}

.product-name {
  font-size: 30rpx;
  color: #2D3748;
  font-weight: 500;
}

.back-btn {
  margin-top: 24rpx;
  padding: 20rpx;
  text-align: center;
  color: #3B82F6;
  font-size: 28rpx;
  border-top: 1rpx solid #E2E8F0;
}

.back-btn:active {
  background: #F7FAFC;
}
