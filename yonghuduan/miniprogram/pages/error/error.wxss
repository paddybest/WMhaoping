/* error.wxss - 优化后的样式 */

/* ===== 页面容器 ===== */
.error-page {
  width: 100%;
  height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  position: relative;
  overflow: hidden;
}

/* 背景装饰效果 */
.error-bg-decoration {
  position: absolute;
  width: 200%;
  height: 200%;
  top: -50%;
  left: -50%;
  background: radial-gradient(circle, rgba(255,255,255,0.1) 0%, transparent 70%);
  animation: bg-animation 20s ease-in-out infinite;
  pointer-events: none;
}

@keyframes bg-animation {
  0%, 100% {
    transform: translate(0, 0) rotate(0deg);
  }
  50% {
    transform: translate(-10%, -10%) rotate(180deg);
  }
}

/* ===== 错误容器 ===== */
.error-container {
  width: 100%;
  max-width: 600rpx;
  background: #ffffff;
  border-radius: 32rpx;
  padding: 100rpx 80rpx;
  box-shadow: 0 32rpx 80rpx rgba(0, 0, 0, 0.12);
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  animation: container-appear 0.5s ease-out;
}

@keyframes container-appear {
  from {
    opacity: 0;
    transform: translateY(40rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* ===== 错误图标 ===== */
.error-icon-wrapper {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
  border-radius: 50%;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
  position: relative;
  overflow: hidden;
}

.error-icon {
  width: 120rpx;
  height: 120rpx;
}

.error-icon-emoji {
  font-size: 100rpx;
  line-height: 1;
}

.error-icon-text {
  font-size: 80rpx;
  line-height: 1;
}

/* 图标错误处理 */
.error-icon-wrapper[binderror="true"] {
  animation: shake 0.5s ease-in-out;
}

@keyframes shake {
  0%, 100% {
    transform: translateX(0);
  }
  10%, 30%, 50%, 70%, 90% {
    transform: translateX(-10rpx);
  }
  20%, 40%, 60%, 80% {
    transform: translateX(10rpx);
  }
}

/* ===== 错误内容 ===== */
.error-content-wrapper {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 80rpx;
  animation: content-appear 0.6s ease-out 0.3s;
}

@keyframes content-appear {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.error-content {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 60rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
  margin-bottom: 40rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

/* 小图标样式 */
.error-icon-small {
  font-size: 64rpx;
  margin-bottom: 24rpx;
  display: inline-block;
  animation: icon-bounce 0.6s ease-out;
}

@keyframes icon-bounce {
  0%, 20%, 40%, 60%, 80%, 100% {
    transform: translateY(0);
  }
  10%, 30%, 50%, 70%, 90% {
    transform: translateY(-8rpx);
  }
}

.error-text-wrapper {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.error-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333333;
  text-align: center;
  margin-bottom: 16rpx;
  letter-spacing: 1rpx;
}

.error-desc {
  font-size: 28rpx;
  color: #666666;
  text-align: center;
  line-height: 1.6;
}

/* ===== 操作按钮 ===== */
.action-buttons {
  width: 100%;
  display: flex;
  flex-direction: row;
  justify-content: center;
  gap: 24rpx;
  margin-top: 20rpx;
  animation: buttons-appear 0.8s ease-out 0.5s;
}

@keyframes buttons-appear {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.retry-btn,
.back-btn {
  width: 240rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 500;
  border-radius: 16rpx;
  border: none;
  transition: all 0.3s ease;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
  position: relative;
  z-index: 10;
}

.btn-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
  line-height: 1;
}

.btn-text {
  font-size: 30rpx;
}

/* 重试按钮 */
.retry-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
}

.retry-btn-hover {
  transform: translateY(-4rpx);
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.2);
}

/* 返回按钮 */
.back-btn {
  background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
  color: #666666;
  border: 2rpx solid #dee2e6;
}

.back-btn-hover {
  transform: translateY(-4rpx);
  background: linear-gradient(135deg, #e9ecef 0%, #dbeafe 100%);
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
}

/* ===== 底部提示 ===== */
.error-footer {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 60rpx;
  padding-top: 40rpx;
  border-top: 1rpx solid #e9ecef;
  animation: footer-appear 1s ease-out 0.8s;
}

@keyframes footer-appear {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

.footer-tip {
  font-size: 26rpx;
  color: #999999;
  margin-bottom: 24rpx;
}

.contact-btn {
  background: transparent;
  color: #667eea;
  border: none;
  font-size: 28rpx;
  padding: 16rpx 32rpx;
  border-radius: 8rpx;
  font-weight: 500;
  transition: all 0.3s ease;
}

.contact-btn::after {
  content: '';
  position: absolute;
  bottom: -2rpx;
  left: 50%;
  width: 0;
  height: 2rpx;
  background: #667eea;
  transform: translateX(-50%);
  transition: all 0.3s ease;
}

.contact-btn:active {
  background: rgba(102, 126, 234, 0.05);
  transform: scale(0.95);
}

/* ===== 响应式适配 ===== */
@media (max-width: 375px) {
  .error-container {
    padding: 80rpx 60rpx;
    max-width: 90%;
  }

  .error-title {
    font-size: 32rpx;
  }

  .error-desc {
    font-size: 24rpx;
  }

  .action-buttons {
    flex-direction: column;
    gap: 20rpx;
  }

  .retry-btn,
  .back-btn {
    width: 100%;
  }
}

/* 深色模式适配 */
@media (prefers-color-scheme: dark) {
  .error-page {
    background: linear-gradient(135deg, #2d3436 0%, #1a1a2e 100%);
  }

  .error-container {
    background: #2d3748;
  }

  .error-content {
    background: linear-gradient(135deg, #3d3d5e 0%, #2d3748 100%);
  }

  .error-title {
    color: #ffffff;
  }

  .error-desc {
    color: #c9c9c9;
  }

  .back-btn {
    background: linear-gradient(135deg, #3d3d5e 0%, #4a5568 100%);
    color: #ffffff;
    border-color: #5a5a5a;
  }

  .back-btn-hover {
    background: linear-gradient(135deg, #4a5568 0%, #5a5a5a 100%);
  }
}

/* ===== 微信小程序特定优化 ===== */
/* 防止点击穿透 */
.retry-btn::after,
.back-btn::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: transparent;
}

/* 安全区域 - 防止手势冲突 */
.retry-btn,
.back-btn {
  position: relative;
  z-index: 10;
}
