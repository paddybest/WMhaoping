.container {
  min-height: 100vh;
  background: #F0F2F5;
  display: flex;
  flex-direction: column;
  align-items: stretch;
}

.header {
  background: #FFFFFF;
  padding: 30rpx;
  border-bottom: 1rpx solid #EEE;
}

.step-indicator {
  display: flex;
  align-items: center;
  justify-content: center;
}

.step {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.step-circle {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #E5E7EB;
  color: #9CA3AF;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 500;
  margin-bottom: 12rpx;
}

.step.active .step-circle {
  background: #3B82F6;
  color: #FFFFFF;
}

.step.completed .step-circle {
  background: #10B981;
  color: #FFFFFF;
}

.step-text {
  font-size: 24rpx;
  color: #9CA3AF;
}

.step.active .step-text {
  color: #3B82F6;
  font-weight: 500;
}

.step.completed .step-text {
  color: #10B981;
}

.step-line {
  width: 60rpx;
  height: 4rpx;
  background: #E5E7EB;
  margin: 0 16rpx;
  margin-bottom: 36rpx;
}

.step-line.completed {
  background: #10B981;
}

.content {
  padding: 20rpx;
  width: 100%;
  box-sizing: border-box;
}

.section {
  background: #FEFEFE;
  border-radius: 16rpx;
  padding: 32rpx;
  margin: 0 20rpx 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}

.section-desc {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 32rpx;
}

.upload-area {
  width: 100%;
  min-height: 400rpx;
  border: 2rpx dashed #D1D5DB;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
  overflow: hidden;
}

.upload-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx;
}

.upload-icon {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: #F3F4F6;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
  color: #9CA3AF;
  margin-bottom: 20rpx;
}

.upload-text {
  font-size: 28rpx;
  color: #666;
}

.preview-image {
  width: 100%;
  height: 400rpx;
}

.tips {
  background: #FEF3C7;
  border-radius: 12rpx;
  padding: 24rpx;
}

.tip-title {
  font-size: 26rpx;
  font-weight: 500;
  color: #92400E;
  margin-bottom: 12rpx;
}

.tip-item {
  font-size: 24rpx;
  color: #B45309;
  line-height: 1.8;
}

.submit-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #3B82F6, #2563EB);
  border-radius: 48rpx;
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  margin-bottom: 20rpx;
}

.submit-btn.disabled {
  background: #D1D5DB;
  color: #9CA3AF;
}

.skip-link {
  text-align: center;
  font-size: 26rpx;
  color: #3B82F6;
}
