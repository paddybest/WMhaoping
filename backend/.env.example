# ============================================
# Server Configuration
# ============================================
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# ============================================
# Database Configuration
# ============================================
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=password
DB_NAME=haopingbao
DB_NAME_TEST=haopingbao_test  # Test database name

# ============================================
# Redis Configuration (Optional)
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ============================================
# JWT Configuration
# ============================================
# JWT签名密钥（必须至少32个字符，用于Token安全）
# ⚠️ 安全级别：关键 - 必须保密，不可提交到版本控制
JWT_SECRET=your-jwt-secret-key-minimum-32-characters-long
JWT_EXPIRES_IN=7d

# ============================================
# QR Code Configuration (Multi-Tenant)
# ============================================
# 二维码签名密钥（必需，用于防伪造）
# ⚠️ 安全级别：关键 - 必须保密，否则二维码可被伪造
QR_CODE_SECRET=your-qr-code-signing-secret-key-minimum-32-chars

# 二维码URL的基础域名
QR_CODE_BASE_URL=https://yourdomain.com

# 二维码图片尺寸（像素）
QR_CODE_SIZE=300

# 纠错级别（L=7%, M=15%, Q=25%, H=30%）
QR_CODE_ERROR_CORRECTION_LEVEL=M

# ============================================
# AI Service Configuration
# ============================================
DEEPSEEK_API_KEY=your-deepseek-api-key-here

# ============================================
# Alibaba Cloud Wanxiang (万相) AI Configuration
# ============================================
# 阿里云百炼 API Key (通义万相)
DASHSCOPE_API_KEY=your-dashscope-api-key-here
# 是否启用万相图像重绘功能
WANXIANG_ENABLED=true
# 万相 API 地址
WANXIANG_BASE_URL=https://dashscope.aliyuncs.com/api/v1

# ============================================
# File Storage Configuration (Alibaba Cloud OSS)
# ============================================
OSS_ACCESS_KEY_ID=your-oss-access-key-id
OSS_ACCESS_KEY_SECRET=your-oss-secret-key  # ⚠️ 敏感信息，必须保密
OSS_BUCKET=haopingbao-images
OSS_REGION=oss-cn-hangzhou

# ============================================
# WeChat Configuration
# ============================================
WECHAT_APP_ID=your-wechat-app-id
WECHAT_APP_SECRET=your-wechat-app-secret  # ⚠️ 敏感信息，必须保密

# ============================================
# WebSocket Configuration
# ============================================
WS_PORT=5001

# ============================================
# Logging Configuration
# ============================================
# 日志级别（可选值: error, warn, info, debug）
LOG_LEVEL=info

# 日志文件路径
LOG_FILE=logs/combined.log

# 错误日志文件路径
ERROR_LOG_FILE=logs/error.log

# ============================================
# Security Configuration
# ============================================
# 限流时间窗口（毫秒，默认15分钟=900000ms）
RATE_LIMIT_WINDOW_MS=900000

# 时间窗口内最大请求数
RATE_LIMIT_MAX_REQUESTS=100

# 是否启用CORS（true/false）
CORS_ENABLED=true

# 允许的CORS来源
CORS_ORIGIN=http://localhost:3000
